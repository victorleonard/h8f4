---
import { buildMusicGroupSchema, metaDescription, metaTitle, shareImageAlt, shareImageHeight, shareImagePath, shareImageType, shareImageWidth, siteName } from '../data/seo';
import { withBase } from '../utils/path';

interface Props {
  title?: string;
  description?: string;
  /** Page autonome sans navigation du site (ex. /propal). */
  minimal?: boolean;
}

const {
  title = metaTitle,
  description = metaDescription,
  minimal = false,
} = Astro.props;

const noindex = import.meta.env.PUBLIC_NOINDEX === 'true' || minimal;
const siteUrl = (import.meta.env.SITE ?? '').replace(/\/$/, '');
const canonicalUrl = new URL(Astro.url.pathname, `${siteUrl}/`).href;
const ogImage = `${siteUrl}${withBase(shareImagePath)}`;
const musicGroupSchema = buildMusicGroupSchema(siteUrl);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:url" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content={shareImageType} />
    <meta property="og:image:width" content={String(shareImageWidth)} />
    <meta property="og:image:height" content={String(shareImageHeight)} />
    <meta property="og:image:alt" content={shareImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={shareImageAlt} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" type="image/png" sizes="1200x1200" href={withBase('/og-image.png')} />
    <link rel="apple-touch-icon" sizes="1200x1200" href={withBase('/og-image.png')} />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var STORAGE_KEY = "h8f4-theme";

        function getTheme() {
          var current = document.documentElement.getAttribute("data-theme");
          if (current === "light" || current === "dark") return current;
          return window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
        }

        function syncThemeToggleButtons() {
          var isDark = getTheme() === "dark";
          var buttons = document.querySelectorAll("[data-theme-toggle]");
          for (var i = 0; i < buttons.length; i++) {
            var button = buttons[i];
            button.setAttribute(
              "aria-label",
              isDark ? "Activer le mode clair" : "Activer le mode sombre"
            );
            button.setAttribute("aria-pressed", isDark ? "true" : "false");
          }
        }

        function applyTheme(theme) {
          document.documentElement.setAttribute("data-theme", theme);
          document.documentElement.style.colorScheme = theme;
          try {
            localStorage.setItem(STORAGE_KEY, theme);
          } catch (e) {}
          syncThemeToggleButtons();
        }

        window.h8f4ToggleTheme = function (event) {
          if (event && event.preventDefault) event.preventDefault();
          if (event && event.stopPropagation) event.stopPropagation();
          applyTheme(getTheme() === "dark" ? "light" : "dark");
        };

        var stored = null;
        try {
          stored = localStorage.getItem(STORAGE_KEY);
        } catch (e) {}
        applyTheme(
          stored === "light" || stored === "dark"
            ? stored
            : window.matchMedia("(prefers-color-scheme: light)").matches
              ? "light"
              : "dark"
        );

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", syncThemeToggleButtons);
        } else {
          syncThemeToggleButtons();
        }
      })();
    </script>
    {minimal ? null : <script type="application/ld+json" set:html={JSON.stringify(musicGroupSchema)} />}
  </head>
  <body>
    <slot />
    {minimal ? null : <script src="../scripts/main.ts"></script>}
  </body>
</html>
