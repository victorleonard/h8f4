---
import { instagramUrl } from '../data/social';

interface Props {
  class?: string;
  iconClass?: string;
  variant?: 'plain' | 'circle';
  label?: string;
}

const { class: className = '', iconClass = 'h-5 w-5', variant = 'plain', label } = Astro.props;

const baseClass =
  variant === 'circle'
    ? 'flex h-11 w-11 items-center justify-center rounded-full border border-border text-text-muted hover:border-accent hover:text-accent'
    : 'text-text-muted hover:text-accent';
---

<a
  href={instagramUrl}
  class:list={[
    'cursor-pointer transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent',
    label && 'inline-flex items-center gap-3',
    baseClass,
    className,
  ]}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="H8F4 sur Instagram (@h8f4_)"
>
  <svg
    class={iconClass}
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
    <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
  </svg>
  {label && <span>{label}</span>}
</a>
