---
import type { LivePhoto } from '../data/live-assets';
import OptimizedImage from './OptimizedImage.astro';
import { withBase } from '../utils/path';

interface Props {
  photos: LivePhoto[];
}

const { photos } = Astro.props;

const resolvedPhotos = photos.map((photo) => ({
  ...photo,
  srcLarge: withBase(photo.srcLarge),
  alt: photo.alt,
}));
---

<div class="photo-gallery" data-photo-gallery>
  <div class="photo-gallery__slider sm:hidden" data-photo-slider>
    <div class="photo-gallery__viewport">
      <div class="photo-gallery__track" data-photo-track aria-label="Photos live — glissez horizontalement pour parcourir">
      {
        resolvedPhotos.map((photo, i) => (
          <div class="photo-gallery__slide" aria-hidden={i === 0 ? 'false' : 'true'}>
            <OptimizedImage
              photo={photo}
              variant="slide"
              loading={i < 2 ? 'eager' : 'lazy'}
              class="photo-gallery__slide-image"
              draggable={false}
            />
          </div>
        ))
      }
      </div>
    </div>
    <p class="photo-gallery__slider-hint">Glissez horizontalement pour parcourir</p>
    <div class="photo-gallery__dots" data-photo-dots aria-hidden="true">
      {
        resolvedPhotos.map((_, i) => (
          <span class:list={['photo-gallery__dot', i === 0 && 'photo-gallery__dot--active']} data-photo-dot={i} />
        ))
      }
    </div>
  </div>

  <div class="photo-gallery__grid hidden sm:grid">
    {
      resolvedPhotos.map((photo, i) => (
        <button
          type="button"
          class="photo-gallery__thumb"
          data-gallery-open={i}
          aria-label={`Voir ${photo.alt}`}
        >
          <OptimizedImage
            photo={photo}
            variant="thumb"
            loading={i < 4 ? 'eager' : 'lazy'}
            class="photo-gallery__thumb-image"
            draggable={false}
          />
        </button>
      ))
    }
  </div>

  <div
    class="photo-lightbox"
    data-photo-lightbox
    hidden
    aria-hidden="true"
    role="dialog"
    aria-modal="true"
    aria-label="Visionneuse photo"
  >
    <div class="photo-lightbox__backdrop" data-lightbox-close aria-hidden="true"></div>

    <button
      type="button"
      class="photo-lightbox__close"
      data-lightbox-close
      aria-label="Fermer"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>

    <button
      type="button"
      class="photo-lightbox__nav photo-lightbox__nav--prev"
      data-lightbox-prev
      aria-label="Photo précédente"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
    </button>

    <figure class="photo-lightbox__figure" data-lightbox-figure>
      <img
        class="photo-lightbox__image"
        data-lightbox-image
        src=""
        alt=""
        width="1200"
        height="900"
        draggable="false"
        decoding="async"
      />
      <figcaption class="photo-lightbox__caption" data-lightbox-caption></figcaption>
    </figure>

    <button
      type="button"
      class="photo-lightbox__nav photo-lightbox__nav--next"
      data-lightbox-next
      aria-label="Photo suivante"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
    </button>

    <p class="photo-lightbox__counter" data-lightbox-counter></p>
  </div>

  <script type="application/json" data-gallery-photos set:html={JSON.stringify(resolvedPhotos)} />
</div>
