# Obtenir un ID sur https://formspree.io
PUBLIC_FORMSPREE_ID=your_form_id_here

# SQLite — propositions de titres (/propal)
# Chemin du fichier de base (créé automatiquement si absent)
PROPAL_DB_PATH=./data/propal.db

# Mot de passe pour gérer les membres (ajout / modification via Admin)
PROPAL_ADMIN_PASSWORD=

# Docker : port exposé sur l'hôte (@docker/docker-compose.yml, défaut 3000)
# HOST_PORT=3000

# Spotify — liens directs vers les morceaux (optionnel)
# Sans ces variables, un lien de recherche Spotify est utilisé
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# YouTube — lien direct vers une vidéo (optionnel)
# Sans cette variable, un lien de recherche YouTube est utilisé
# YOUTUBE_API_KEY=

# Déploiement en sous-dossier (ex. https://example.com/h8f4/)
# Laisser vide ou commenter pour la racine du domaine (https://h8f4.fr/)
# PUBLIC_BASE_PATH=/h8f4/
# PUBLIC_SITE_URL=https://example.com/h8f4

# Bloquer l'indexation (préprod / démo) — retirer ou passer à false en production
# PUBLIC_NOINDEX=true
